const TelegramBot = require('node-telegram-bot-api');
const axios = require('axios');
const fs = require('fs');

const TOKEN = '8390504344:AAGjUIy3bUUPZ_B8yJsg-eaVD0QOGkbJBCs';
const XYRON_URL = 'https://congenial-succotash-pjqwpjxj4456h5gw-3000.app.github.dev';
const DATA_FILE = './wallets.json';

let wallets = {};
if (fs.existsSync(DATA_FILE)) wallets = JSON.parse(fs.readFileSync(DATA_FILE));

function saveWallets() {
    fs.writeFileSync(DATA_FILE, JSON.stringify(wallets, null, 2));
}

const bot = new TelegramBot(TOKEN, { polling: true });

const menu = {
    reply_markup: {
        keyboard: [
            ['📊 STATUS', '📦 BLOCKS'],
            ['💰 HARGA', '👛 WALLET'],
            ['➕ BUAT WALLET', '✉️ SMS'],
            ['🔑 PRIVATE KEY', '❓ HELP']
        ],
        resize_keyboard: true
    }
};

bot.onText(/\/start/, (msg) => {
    const chatId = msg.chat.id;
    bot.sendMessage(chatId, 
        `╔════════════════════════╗\n` +
        `║  🚀 XYRON BLOCKCHAIN   ║\n` +
        `║   TERMINAL MEWAH v2.0  ║\n` +
        `╚════════════════════════╝\n\n` +
        `Halo *${msg.from.first_name}*!\n` +
        `Pilih menu di bawah 👇`,
    { parse_mode: 'Markdown', ...menu });
});

bot.on('message', async (msg) => {
    const chatId = msg.chat.id;
    const text = msg.text;
    
    if (text === '📊 STATUS') {
        try {
            const res = await axios.get(`${XYRON_URL}/health`);
            const d = res.data;
            let icon = d.message === 'PIP' ? '🟢' : '🟡';
            bot.sendMessage(chatId,
                `📊 *STATUS JARINGAN*\n` +
                `━━━━━━━━━━━━━━━\n` +
                `${icon} Status: ${d.message}\n` +
                `#️⃣ Block: ${d.block}\n` +
                `✅ Go: ${d.go}\n` +
                `🦀 Rust: ${d.rust}\n` +
                `👥 Validator: ${d.activeValidators}`,
            { parse_mode: 'Markdown', ...menu });
        } catch {
            bot.sendMessage(chatId, '❌ Gagal konek', menu);
        }
    }
    
    else if (text === '📦 BLOCKS') {
        try {
            const res = await axios.get(`${XYRON_URL}/blocks`);
            const blocks = res.data.blocks || res.data;
            let pesan = '📦 *5 BLOCK TERBARU*\n━━━━━━━━━━━━\n';
            blocks.slice(0,5).forEach((b,i) => {
                pesan += `${i+1}. #${b.header?.block} • ${b.header?.timestamp?.slice(11,16)}\n`;
            });
            bot.sendMessage(chatId, pesan, { parse_mode: 'Markdown', ...menu });
        } catch {
            bot.sendMessage(chatId, '❌ Gagal ambil blocks', menu);
        }
    }
    
    else if (text === '💰 HARGA') {
        const harga = (Math.random() * 0.5 + 0.2).toFixed(4);
        bot.sendMessage(chatId,
            `💰 *HARGA XYR*\n━━━━━━━━━━\n` +
            `USD: $${harga}\n` +
            `IDR: Rp${(harga * 15500).toFixed(0)}\n` +
            `24h: +${(Math.random()*10).toFixed(2)}%`,
        { parse_mode: 'Markdown', ...menu });
    }
    
    else if (text === '➕ BUAT WALLET') {
        const privateKey = [...Array(64)].map(() => Math.floor(Math.random()*16).toString(16)).join('').toUpperCase();
        const publicKey = [...Array(40)].map(() => Math.floor(Math.random()*16).toString(16)).join('').toUpperCase();
        const address = `X11_${publicKey}`;
        
        wallets[chatId] = { address, privateKey };
        saveWallets();
        
        bot.sendMessage(chatId,
            `✅ *WALLET BARU*\n━━━━━━━━━━━━\n` +
            `📱 *Address:*\n\`${address}\`\n\n` +
            `🔑 *Private Key:*\n\`${privateKey}\`\n\n` +
            `⚠️ *Simpan Private Key baik-baik!*`,
        { parse_mode: 'Markdown', ...menu });
    }
    
    else if (text === '👛 WALLET') {
        const w = wallets[chatId];
        if (!w) return bot.sendMessage(chatId, '❌ Belum punya wallet', menu);
        bot.sendMessage(chatId,
            `👛 *WALLET ANDA*\n━━━━━━━━━━\n` +
            `📱 Address:\n\`${w.address}\`\n\n` +
            `💰 Saldo: 0 XYR`,
        { parse_mode: 'Markdown', ...menu });
    }
    
    else if (text === '🔑 PRIVATE KEY') {
        const w = wallets[chatId];
        if (!w) return bot.sendMessage(chatId, '❌ Belum punya wallet', menu);
        bot.sendMessage(chatId,
            `🔐 *PRIVATE KEY*\n━━━━━━━━━━\n\`${w.privateKey}\`\n\n` +
            `⚠️ *RAHASIA! Jangan share!*`,
        { parse_mode: 'Markdown', ...menu });
    }
    
    else if (text === '✉️ SMS') {
        bot.sendMessage(chatId, '📝 Fitur SMS menyusul...', menu);
    }
    
    else if (text === '❓ HELP') {
        bot.sendMessage(chatId,
            `❓ *BANTUAN*\n━━━━━━━━\n` +
            `📊 Status jaringan\n` +
            `📦 Block terbaru\n` +
            `💰 Harga XYR\n` +
            `👛 Lihat wallet\n` +
            `➕ Buat wallet baru\n` +
            `🔑 Lihat private key`,
        { parse_mode: 'Markdown', ...menu });
    }
});

console.log('╔════════════════════════╗');
console.log('║  🤖 BOT MEWAH JALAN   ║');
console.log('║  Kirim /start ke bot  ║');
console.log('╚════════════════════════╝');
